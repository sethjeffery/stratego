# Frontend (Vite) - Socket backend mode
# For local dev you can leave blank because Vite proxy points at localhost:3001.
# In production, set this to your deployed Node backend URL.
# Leave empty when using Supabase direct mode only.
VITE_BACKEND_ORIGIN=

# Frontend (Vite) - Supabase direct mode (no custom backend required)
# These two values are required for Supabase mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend (Node server; only needed for socket mode)
CLIENT_ORIGIN=http://localhost:5173
